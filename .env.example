# Firebase Configuration
# Get these values from Firebase Console: https://console.firebase.google.com
# 1. Click gear icon → Project Settings
# 2. Scroll to "Your apps" section
# 3. Click "Config" for web app
# 4. Copy each value to environment variables below

# Firebase Web App Config
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Web Push VAPID Key
# Get this from Firebase Console: Messaging → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Backend Firebase Configuration
# Download service account key from Firebase Console
# Store as: android/app/src/main/resources/firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=android/app/src/main/resources/firebase-adminsdk.json
